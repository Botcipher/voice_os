# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# n8n
N8N_BASE_URL=https://your-n8n-instance.com
N8N_BOOKING_WEBHOOK=https://your-n8n-instance.com/webhook/booking
